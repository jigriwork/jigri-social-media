# Copy this file to `.env.local` and fill in your real Supabase values.

# Required for app authentication, API routes, and data access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for privileged server-side API routes (admin/public profile fallback)
SUPABASE_SERVICE_ROLE_KEY=

# Optional for production/deployment URL handling
NEXT_PUBLIC_APP_URL=